<div class="page-header">
  <h1>My Dashboard</h1>
  <p>Track the events you've registered for and your attendance status.</p>
</div>

<div class="grid grid-3 mb-24">
  <div class="stat-tile">
    <div class="value" id="stat-registered">–</div>
    <div class="label">Registered Events</div>
  </div>
  <div class="stat-tile">
    <div class="value" id="stat-attended">–</div>
    <div class="label">Events Attended</div>
  </div>
  <div class="stat-tile">
    <div class="value" id="stat-certificates">–</div>
    <div class="label">Certificates Earned</div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <h3 style="color: var(--color-primary);">My Registered Events</h3>
    <table class="data-table mt-24" id="my-events-table">
      <thead>
        <tr><th>Event</th><th>Date</th><th>Status</th><th>QR Pass</th></tr>
      </thead>
      <tbody>
        <tr><td colspan="4" class="text-center">Loading your events…</td></tr>
      </tbody>
    </table>
  </div>
</div>
<script src="/js/main.js"></script>
