<div class="card auth-card">
  <h1>Create your account</h1>
  <p class="subtitle">Join CEMS to register for campus events.</p>
  <form id="register-form">
    <div class="form-group">
      <label for="name">Full Name</label>
      <input class="form-control" type="text" id="name" name="name" required />
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input class="form-control" type="email" id="email" name="email" required />
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <input class="form-control" type="password" id="password" name="password" minlength="6" required />
    </div>
    <div class="form-group">
      <label for="collegeId">College ID</label>
      <input class="form-control" type="text" id="collegeId" name="collegeId" />
    </div>
    <div class="form-group">
      <label for="department">Department</label>
      <input class="form-control" type="text" id="department" name="department" />
    </div>
    <div class="form-group">
      <label for="role">I am a</label>
      <select class="form-control" id="role" name="role">
        <option value="student">Student</option>
        <option value="organizer">Organizer</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary btn-block">Sign Up</button>
  </form>
  <p class="text-center mt-24">
    Already have an account? <a href="/login">Log in</a>
  </p>
</div>
